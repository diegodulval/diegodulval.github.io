---
const metrics = [
  { value: '4 anos', label: 'como founding engineer em fintech de pagamentos' },
  { value: '12+', label: 'anos construindo produto' },
  { value: '12+', label: 'produtos entregues do zero' },
  { value: '5', label: 'verticais: fintech · adtech · IoT · saúde · varejo' },
  { value: '3 países', label: 'times no Brasil, EUA e Europa' },
];
---
<section class="section">
  <div class="container">
    <div class="metrics">
      {metrics.map((m) => (
        <div class="metric">
          <span class="metric-value">{m.value}</span>
          <span class="metric-label">{m.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.metrics {
  display: flex;
}

.metric {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: var(--sp-5) var(--sp-4);
  border-right: 1px solid var(--border);
}

.metric:first-child {
  padding-left: 0;
}

.metric:last-child {
  border-right: none;
}

.metric-value {
  font-size: var(--fs-2xl);
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  line-height: 1;
}

.metric-label {
  font-size: var(--fs-sm);
  color: var(--text-muted);
  letter-spacing: 0.01em;
  line-height: 1.45;
}

@media (max-width: 768px) {
  .metrics {
    flex-wrap: wrap;
  }

  .metric {
    flex: 0 0 50%;
    border-right: none;
    border-bottom: 1px solid var(--border);
    padding: var(--sp-3);
  }

  .metric:last-child {
    border-bottom: none;
  }

  .metric:first-child {
    padding-left: var(--sp-3);
  }
}
</style>
