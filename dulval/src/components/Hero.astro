---
import videoSrc from '../assets/me.mp4';
---

<section class="hero-wrap">
  <div class="hero-card" id="heroCard">
    <video class="hero-video" autoplay muted loop playsinline>
      <source src={videoSrc} type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="eyebrow">Founding Engineer · FinTech · AI · Mobile</span>
        <h1 class="hero-title">Do zero ao produto.<br>Em escala real.</h1>
        <p class="hero-body">
          Founding Staff Engineer na Noh — construí a plataforma de pagamentos
          do zero até +R$60M em TPV mensal. Backend, mobile, integrações financeiras e AI:
          engenharia de sistemas com sensibilidade de produto.
        </p>
        <div class="hero-actions">
          <a href="mailto:diego@dulval.com" class="hero-btn-primary">Fale comigo</a>
          <a href="/projetos" class="hero-btn-ghost">Ver projetos</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero-wrap {
  padding-top: var(--sp-4);
  padding-bottom: var(--sp-5);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}

.hero-card {
  position: relative;
  height: 520px;
  overflow: hidden;
  background: linear-gradient(150deg, #0d0d0c 0%, #171714 55%, #222218 100%);
  will-change: width, margin-left, border-radius;
}

.hero-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(
    to right,
    rgba(13, 13, 12, 0.92) 0%,
    rgba(13, 13, 12, 0.55) 55%,
    rgba(13, 13, 12, 0.05) 100%
  );
}

/* container inside the card — alinha o texto com o resto da página */
.hero-inner {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  align-items: flex-end;
}

.hero-content {
  max-width: 560px;
  padding-bottom: var(--sp-5);
}

.hero-content .eyebrow {
  color: rgba(255, 255, 255, 0.38);
}

.hero-title {
  font-size: var(--fs-hero);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.025em;
  line-height: 1.08;
  margin-top: var(--sp-4);
  margin-bottom: var(--sp-4);
}

.hero-body {
  font-size: var(--fs-md);
  color: rgba(255, 255, 255, 0.52);
  line-height: 1.65;
  margin-bottom: var(--sp-4);
}

.hero-actions {
  display: flex;
  gap: var(--sp-2);
  flex-wrap: wrap;
}

.hero-btn-primary,
.hero-btn-ghost {
  display: inline-flex;
  align-items: center;
  padding: 10px 22px;
  font-family: 'DM Sans', sans-serif;
  font-size: var(--fs-sm);
  font-weight: 500;
  border-radius: var(--radius-pill);
  transition: opacity 0.15s;
  line-height: 1;
  text-decoration: none;
}

.hero-btn-primary {
  background: #ffffff;
  color: #0d0d0c;
}

.hero-btn-primary:hover { opacity: 0.85; }

.hero-btn-ghost {
  background: transparent;
  color: rgba(255, 255, 255, 0.65);
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.hero-btn-ghost:hover {
  border-color: rgba(255, 255, 255, 0.45);
  color: #ffffff;
}
</style>

<script>
  const card = document.getElementById('heroCard') as HTMLElement;
  const CONTAINER_MAX = 960;
  const PADDING = 48;
  const RADIUS = 16;
  const SCROLL_THRESHOLD = 320;

  function ease(t: number): number {
    return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
  }

  function update() {
    const progress = ease(Math.min(window.scrollY / SCROLL_THRESHOLD, 1));
    const vw = window.innerWidth;
    const targetW = Math.min(CONTAINER_MAX, vw - PADDING * 2);
    const currentW = vw + (targetW - vw) * progress;
    const margin = (vw - currentW) / 2;

    card.style.width = `${currentW}px`;
    card.style.marginLeft = `${margin}px`;
    card.style.borderRadius = `${RADIUS * progress}px`;
  }

  update();
  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update, { passive: true });
</script>
