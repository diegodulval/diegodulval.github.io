---
import logoRaw from '../assets/dd-logo.svg?raw';
---
<nav class="nav" id="nav">
  <div class="container nav-inner">
    <ul class="nav-links nav-links--left">
      <li><a href="/sobre">Sobre</a></li>
      <li><a href="/projetos">Projetos</a></li>
    </ul>
    <a href="/" class="nav-logo" set:html={logoRaw} />
    <ul class="nav-links nav-links--right">
      <li><a href="/trajetoria">Trajetória</a></li>
      <li><a href="/contato">Contato</a></li>
    </ul>
  </div>
</nav>

<!-- Pill flutuante -->
<button class="nav-pill" id="navPill" aria-label="Abrir menu" style="opacity:0;pointer-events:none">
  <span class="nav-pill__logo" set:html={logoRaw} />
  <span class="nav-pill__divider"></span>
  <span class="nav-pill__label">Menu</span>
</button>

<!-- Overlay do menu -->
<div class="menu-overlay" id="menuOverlay" style="opacity:0;pointer-events:none">
  <div class="menu-overlay__inner">
    <button class="menu-overlay__close" id="menuClose" aria-label="Fechar menu">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <nav class="menu-overlay__nav">
      <a href="/" class="menu-overlay__link">Início</a>
      <a href="/sobre" class="menu-overlay__link">Sobre</a>
      <a href="/projetos" class="menu-overlay__link">Projetos</a>
      <a href="/trajetoria" class="menu-overlay__link">Trajetória</a>
      <a href="/contato" class="menu-overlay__link">Contato</a>
    </nav>
  </div>
</div>

<style>
/* ── Navbar principal ── */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 88px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  transition: opacity 0.25s, transform 0.25s;
}

.nav.nav--hidden {
  opacity: 0;
  pointer-events: none;
  transform: translateY(-8px);
}

.nav-inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
}

.nav-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 0;
  padding: 0 var(--sp-5);
}

.nav-logo :global(svg) {
  width: 26px;
  height: auto;
}

.nav-logo :global(svg path) {
  fill: var(--text-primary);
  stroke: none;
}

.nav-links {
  display: flex;
  gap: var(--sp-5);
  align-items: center;
}

.nav-links--left  { justify-content: flex-start; }
.nav-links--right { justify-content: flex-end; }

.nav-links a {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  transition: color 0.15s;
}

.nav-links a:hover { color: var(--text-primary); }

/* ── Pill flutuante ── */
.nav-pill {
  position: fixed;
  top: 20px;
  left: 50%;
  transform: translateX(-50%) translateY(-8px);
  z-index: 101;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 20px 10px 14px;
  background: var(--text-primary);
  border: none;
  border-radius: 100px;
  cursor: pointer;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s, transform 0.25s, box-shadow 0.2s;
  box-shadow: 0 4px 24px rgba(0,0,0,0.18);
}

.nav-pill.nav-pill--visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateX(-50%) translateY(0);
}

.nav-pill:hover {
  box-shadow: 0 6px 32px rgba(0,0,0,0.28);
}

.nav-pill__logo {
  display: flex;
  align-items: center;
  line-height: 0;
}

.nav-pill__logo :global(svg) {
  width: 20px;
  height: auto;
}

.nav-pill__logo :global(svg path) {
  fill: var(--bg);
  stroke: none;
}

.nav-pill__divider {
  width: 1px;
  height: 14px;
  background: rgba(255,255,255,0.2);
}

.nav-pill__label {
  font-size: var(--fs-sm);
  font-weight: 500;
  color: var(--bg);
  letter-spacing: 0.02em;
}

/* ── Overlay do menu ── */
.menu-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.menu-overlay.menu-overlay--open {
  opacity: 1;
  pointer-events: auto;
}

.menu-overlay__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-6);
}

.menu-overlay__close {
  position: absolute;
  top: 24px;
  right: 32px;
  background: none;
  border: none;
  color: var(--text-secondary);
  cursor: pointer;
  padding: 8px;
  transition: color 0.15s;
}

.menu-overlay__close:hover { color: var(--text-primary); }

.menu-overlay__nav {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-4);
}

.menu-overlay__link {
  font-size: clamp(28px, 5vw, 48px);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  transition: color 0.15s;
}

.menu-overlay__link:hover { color: var(--text-muted); }

/* ── Responsive ── */
@media (max-width: 768px) {
  .nav-links { display: none; }
}
</style>

<script>
  const nav = document.getElementById('nav')!;
  const pill = document.getElementById('navPill')!;
  const overlay = document.getElementById('menuOverlay')!;
  const closeBtn = document.getElementById('menuClose')!;

  const SCROLL_THRESHOLD = 80;
  let pillReady = false;

  const showPill = () => {
    nav.classList.add('nav--hidden');
    if (!pillReady) {
      pill.removeAttribute('style');
      pillReady = true;
    }
    requestAnimationFrame(() => pill.classList.add('nav-pill--visible'));
  };

  const hidePill = () => {
    nav.classList.remove('nav--hidden');
    pill.classList.remove('nav-pill--visible');
  };

  window.addEventListener('scroll', () => {
    window.scrollY > SCROLL_THRESHOLD ? showPill() : hidePill();
  }, { passive: true });

  pill.addEventListener('click', () => {
    overlay.removeAttribute('style');
    requestAnimationFrame(() => overlay.classList.add('menu-overlay--open'));
    document.body.style.overflow = 'hidden';
  });

  const closeMenu = () => {
    overlay.classList.remove('menu-overlay--open');
    document.body.style.overflow = '';
  };

  closeBtn.addEventListener('click', closeMenu);

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
