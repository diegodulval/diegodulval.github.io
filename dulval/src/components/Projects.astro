---
const projects = [
  {
    company: 'Noh',
    role: 'Founding Staff Engineer',
    period: '2022 – 2026',
    href: '/projetos/noh',
    size: 'var(--fs-2xl)',
    weight: '700',
  },
  {
    company: 'Avenue Code',
    role: 'Tech Lead · AI Engineer',
    period: '2019 – 2022',
    href: '/projetos/avenue-code',
    size: 'var(--fs-lg)',
    weight: '600',
  },
  {
    company: 'Aurora',
    role: 'CTO · Founder',
    period: '2018 – 2019',
    href: '/projetos/aurora',
    size: 'var(--fs-xl)',
    weight: '500',
  },
  {
    company: 'FAI / NPDI',
    role: 'Software Engineer',
    period: '2017 – 2018',
    href: '/projetos/fai-npdi',
    size: 'var(--fs-md)',
    weight: '600',
  },
  {
    company: 'Inatel',
    role: 'Software Developer',
    period: '2016 – 2017',
    href: '/projetos/inatel',
    size: 'var(--fs-lg)',
    weight: '400',
  },
];
---
<section class="section">
  <div class="container">
    <span class="eyebrow">Onde atuei</span>
    <div class="projects gap-grid">
      {projects.map((p) => (
        <a href={p.href} class="project-cell">
          <span class="project-company" style={`font-size: ${p.size}; font-weight: ${p.weight};`}>
            {p.company}
          </span>
          <span class="project-role">{p.role}</span>
          <span class="project-period">{p.period}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.projects {
  grid-template-columns: repeat(5, 1fr);
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-top: var(--sp-4);
}

.project-cell {
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
  padding: var(--sp-4) var(--sp-3);
  transition: background 0.15s;
  text-decoration: none;
}

.project-cell:hover {
  background: var(--surface-dim);
}

.project-company {
  color: var(--text-primary);
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.project-role {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  margin-top: var(--sp-2);
}

.project-period {
  font-size: var(--fs-sm);
  color: var(--text-muted);
}

@media (max-width: 768px) {
  .projects {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>
