---
import Layout from '../../layouts/Layout.astro';
import logoRaw from '../../assets/dd-logo.svg?raw';

const steps = [
  {
    n: '01',
    title: 'Diagnóstico',
    desc: 'Uma conversa direta sobre o seu negócio: onde estão os gargalos, quais tarefas drenam tempo e onde a IA pode gerar valor imediato.',
  },
  {
    n: '02',
    title: 'Construção',
    desc: 'Desenvolvo o agente ou sistema sob medida — integrado às suas ferramentas, do jeito que o seu time já trabalha.',
  },
  {
    n: '03',
    title: 'Entrega & Evolução',
    desc: 'Você assume o controle. Continuo disponível para iterar, melhorar e escalar conforme o uso real.',
  },
];

const services = [
  {
    dor: 'Meu time perde horas em tarefas repetitivas',
    solucao: 'Agentes de automação',
    desc: 'Workflows inteligentes que executam tarefas operacionais sem intervenção humana — triagem de e-mails, relatórios, integrações entre sistemas.',
  },
  {
    dor: 'Preciso analisar dados, mas não tenho equipe de dados',
    solucao: 'BI com linguagem natural',
    desc: 'Dashboards e consultas em linguagem natural. Pergunte em português, receba a análise na hora — sem SQL, sem analista.',
  },
  {
    dor: 'Atendimento manual não escala',
    solucao: 'Atendimento com IA',
    desc: 'Agentes de conversação treinados no seu negócio, integrados ao WhatsApp, site ou CRM — disponíveis 24h com qualidade consistente.',
  },
  {
    dor: 'Meu time não sabe usar IA de verdade',
    solucao: 'Workshop e implantação',
    desc: 'Formação prática para equipes + implantação de ferramentas de IA no fluxo de trabalho existente. Resultado em dias, não meses.',
  },
];
---

<Layout
  title="conecta.dulval — IA que resolve problemas reais"
  description="Automação, agentes de IA e sistemas inteligentes para negócios. Construídos por um engenheiro que já rodou produção — direto com você."
>

<style is:global>
  body { padding-top: 0; }
  :root { --accent: #0ea5e9; }
</style>

<!-- NAV -->
<nav class="portal-nav">
  <div class="container portal-nav-inner">
    <a href="/" class="portal-logo" set:html={logoRaw} />
    <span class="portal-nav-name">conecta.dulval</span>
    <a href="https://dulval.com" class="portal-nav-back">← ecossistema</a>
  </div>
</nav>

<!-- HERO -->
<section class="c-hero">
  <div class="c-hero-grid" aria-hidden="true"></div>
  <div class="container c-hero-inner">

    <span class="eyebrow" style="color: var(--accent);">Conecta · IA para negócios</span>
    <h1 class="c-hero-title">
      Resolvo os<br>
      <span class="tw-line">
        <span id="tw" class="tw-word" aria-live="polite"></span><span class="tw-cursor" aria-hidden="true">|</span>
      </span><br>
      do seu negócio.
    </h1>

    <div class="capture-card">
      <span class="brk tl"></span>
      <span class="brk tr"></span>
      <span class="brk bl"></span>
      <span class="brk br"></span>

      <p class="capture-q">Qual é a sua dor hoje?</p>
      <div class="pills">
        <button class="pill" data-area="Automação">Automação</button>
        <button class="pill" data-area="Análise de dados">Análise de dados</button>
        <button class="pill" data-area="Atendimento">Atendimento</button>
        <button class="pill" data-area="Integrações">Integrações</button>
        <button class="pill" data-area="Tecnologia">Tecnologia</button>
        <button class="pill" data-area="Produção">Produção</button>
        <button class="pill" data-area="Produto">Produto</button>
        <button class="pill" data-area="Serviço">Serviço</button>
        <button class="pill active" data-area="Outros">Outros</button>
      </div>

      <textarea id="prob-input" class="capture-ta" placeholder="Descreve o problema com mais detalhes — área, contexto, o que já tentou..." rows="4"></textarea>
      <button class="capture-send" id="send-btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Falar no WhatsApp
      </button>
    </div>

  </div>
</section>

<!-- COMO FUNCIONA -->
<section class="section">
  <div class="container">
    <span class="eyebrow">Como funciona</span>
    <h2 class="s-title">Três passos, resultado real</h2>
    <div class="steps-grid">
      {steps.map((s) => (
        <div class="step-card">
          <span class="step-n" style="color: var(--accent);">{s.n}</span>
          <h3 class="step-title">{s.title}</h3>
          <p class="step-desc">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SERVIÇOS -->
<section class="section" id="servicos">
  <div class="container">
    <span class="eyebrow">Serviços</span>
    <h2 class="s-title">Você tem a dor. Eu tenho a solução.</h2>
    <div class="services-grid">
      {services.map((s) => (
        <div class="service-card">
          <p class="service-dor">"{s.dor}"</p>
          <h3 class="service-sol">{s.solucao}</h3>
          <p class="service-desc">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section" id="faq">
  <div class="container">
    <span class="eyebrow">Perguntas frequentes</span>
    <h2 class="s-title">Antes de falar comigo.</h2>
    <dl class="faq-list">

      <details class="faq-item">
        <summary class="faq-q">
          <dt>Vou precisar trocar de sistema?</dt>
          <span class="faq-icon" aria-hidden="true">+</span>
        </summary>
        <dd class="faq-a">Não. O agente ou a automação é construída em volta do que você já usa — seja ERP, planilha, CRM ou qualquer outra ferramenta. A ideia é encaixar, não substituir.</dd>
      </details>

      <details class="faq-item">
        <summary class="faq-q">
          <dt>Quanto custa?</dt>
          <span class="faq-icon" aria-hidden="true">+</span>
        </summary>
        <dd class="faq-a">Depende do escopo. Projetos pontuais partem de R$ 5.000. Sistemas mais complexos com agentes e integrações ficam na faixa de R$ 15.000–40.000. Os valores são fechados depois de entender o problema — sem surpresa no meio do caminho.</dd>
      </details>

      <details class="faq-item">
        <summary class="faq-q">
          <dt>E se parar de funcionar?</dt>
          <span class="faq-icon" aria-hidden="true">+</span>
        </summary>
        <dd class="faq-a">Você fala direto comigo — sem fila de suporte, sem ticket. Para projetos com retainer mensal, o acordo inclui SLA de resposta e correção. Para projetos avulsos, entrego documentação completa e você tem autonomia total sobre o que foi construído.</dd>
      </details>

      <details class="faq-item">
        <summary class="faq-q">
          <dt>Minha equipe precisa ser técnica?</dt>
          <span class="faq-icon" aria-hidden="true">+</span>
        </summary>
        <dd class="faq-a">Não. Entrego sistemas que o time usa sem precisar entender o que está por baixo. Se quiser, incluo uma sessão de capacitação prática — mas o objetivo é que funcione sem depender de ninguém técnico no seu lado.</dd>
      </details>

      <details class="faq-item">
        <summary class="faq-q">
          <dt>Onde ficam os meus dados?</dt>
          <span class="faq-icon" aria-hidden="true">+</span>
        </summary>
        <dd class="faq-a">Você escolhe. Posso usar a infraestrutura que você já tem, ou montar em cloud (GCP, AWS) com acesso e controle total seu. Nenhum dado fica em sistemas meus — você é o dono.</dd>
      </details>

      <details class="faq-item">
        <summary class="faq-q">
          <dt>Como começa?</dt>
          <span class="faq-icon" aria-hidden="true">+</span>
        </summary>
        <dd class="faq-a">Com uma conversa. Você conta o desafio, eu avalio se consigo resolver e proponho o caminho — sem processo de vendas, sem gerente de conta. Você fala com o engenheiro que vai construir o sistema desde o primeiro contato.</dd>
      </details>

    </dl>
  </div>
</section>

<!-- CONTATO -->
<section class="section" id="contato">
  <div class="container">
    <span class="eyebrow">Contato</span>
    <h2 class="s-title">Vamos conversar.</h2>
    <p class="contact-sub">Conta o desafio. Respondo em até 24h.</p>
    <form class="contact-form" action="mailto:diego@dulval.com" method="get" enctype="text/plain">
      <div class="form-row">
        <input type="text" name="name" placeholder="Seu nome" class="form-input" required />
        <input type="email" name="email" placeholder="E-mail" class="form-input" required />
      </div>
      <textarea name="body" placeholder="Descreva o desafio do seu negócio..." class="form-textarea" rows="5" required></textarea>
      <button type="submit" class="btn btn-primary" style="background: var(--accent);">Enviar →</button>
    </form>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <div class="container footer-inner">
    <a href="/" class="footer-logo" aria-label="Início" set:html={logoRaw} />
    <p class="footer-copy">conecta.dulval.com &nbsp;·&nbsp; © dulval 2026</p>
    <a href="/me" class="footer-back">me.dulval →</a>
  </div>
</footer>

<script>
// ── Typewriter ──
const words = ['gargalos', 'retrabalho', 'dados parados', 'atendimento manual'];
let wi = 0, ci = 0, deleting = false;
const twEl = document.getElementById('tw')!;

function tick() {
  const word = words[wi];
  if (!deleting) {
    twEl.textContent = word.slice(0, ci + 1);
    ci++;
    if (ci === word.length) { deleting = true; setTimeout(tick, 2200); return; }
  } else {
    twEl.textContent = word.slice(0, ci - 1);
    ci--;
    if (ci === 0) { deleting = false; wi = (wi + 1) % words.length; }
  }
  setTimeout(tick, deleting ? 50 : 95);
}
tick();

// ── Form ──
let selectedArea = 'Outros';

document.querySelectorAll<HTMLButtonElement>('.pill').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    selectedArea = btn.dataset.area ?? 'Outros';
  });
});

document.getElementById('send-btn')!.addEventListener('click', () => {
  const problem = (document.getElementById('prob-input') as HTMLTextAreaElement).value.trim();
  // ← substituir pelo seu número com DDI: 5535XXXXXXXXX
  const phone = '5535997660281';
  const msg = encodeURIComponent(
    `Olá Diego, vim do conecta.dulval.com.\n\nÁrea: ${selectedArea}\nProblema: ${problem || '(não especificado)'}`
  );
  window.open(`https://wa.me/${phone}?text=${msg}`, '_blank');
});
</script>

</Layout>

<style>
/* ── Nav ── */
.portal-nav {
  height: 64px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
}
.portal-nav-inner {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
}
.portal-logo { display: flex; align-items: center; line-height: 0; }
.portal-logo :global(svg) { width: 22px; height: auto; }
.portal-logo :global(svg path) { fill: var(--text-primary); stroke: none; }
.portal-nav-name {
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--text-primary);
}
.portal-nav-back {
  margin-left: auto;
  font-size: var(--fs-sm);
  color: var(--text-muted);
  transition: color 0.15s;
}
.portal-nav-back:hover { color: var(--text-primary); }

/* ── Hero ── */
.c-hero {
  position: relative;
  padding: var(--sp-7) 0 var(--sp-7);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}
.c-hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size: 40px 40px;
  opacity: 0.6;
  pointer-events: none;
}
.c-hero-inner {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  position: relative;
}
.c-hero-title {
  font-size: var(--fs-hero);
  font-weight: 700;
  letter-spacing: -0.028em;
  line-height: 1.08;
  margin: var(--sp-3) 0 var(--sp-4);
}
.tw-line {
  color: var(--accent);
  display: inline-block;
  min-height: 1.1em;
}
.tw-cursor {
  display: inline-block;
  color: var(--accent);
  animation: blink 0.75s step-end infinite;
  margin-left: 1px;
}
@keyframes blink { 50% { opacity: 0; } }
.c-hero-body {
  font-size: var(--fs-md);
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 560px;
  margin-bottom: var(--sp-5);
}

/* ── Capture card ── */
.capture-card {
  position: relative;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--sp-5) var(--sp-6);
  width: 100%;
  box-shadow: 0 4px 32px rgba(0,0,0,0.06);
}
.brk {
  position: absolute;
  width: 14px;
  height: 14px;
  border-color: var(--accent);
  border-style: solid;
}
.brk.tl { top: -1px; left: -1px; border-width: 2px 0 0 2px; border-radius: 2px 0 0 0; }
.brk.tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; border-radius: 0 2px 0 0; }
.brk.bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; border-radius: 0 0 0 2px; }
.brk.br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; border-radius: 0 0 2px 0; }
.capture-q {
  font-size: var(--fs-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--sp-3);
  line-height: 1.4;
}
.pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.pill {
  font-family: 'DM Sans', sans-serif;
  font-size: var(--fs-sm);
  font-weight: 500;
  color: var(--text-secondary);
  background: var(--surface-dim);
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 8px 16px;
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s, background 0.15s;
}
.pill:hover { border-color: var(--accent); color: var(--accent); }
.pill.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
}
.capture-ta {
  margin-top: var(--sp-4);
  font-family: 'DM Sans', sans-serif;
  font-size: var(--fs-sm);
  width: 100%;
  padding: 10px var(--sp-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--surface-dim);
  color: var(--text-primary);
  resize: none;
  transition: border-color 0.15s;
  margin-bottom: var(--sp-2);
  display: block;
  box-sizing: border-box;
}
.capture-ta:focus { outline: none; border-color: var(--accent); }
.capture-send {
  font-family: 'DM Sans', sans-serif;
  font-size: var(--fs-sm);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  background: #25D366;
  color: #fff;
  border: none;
  border-radius: var(--radius-pill);
  padding: 11px 20px;
  cursor: pointer;
  transition: opacity 0.15s;
}
.capture-send:hover { opacity: 0.88; }

/* ── Section title ── */
.s-title {
  font-size: var(--fs-2xl);
  font-weight: 700;
  letter-spacing: -0.025em;
  margin: var(--sp-2) 0 var(--sp-4);
}

/* ── Steps ── */
.steps-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-2);
}
.step-card {
  padding: var(--sp-4);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
}
.step-n {
  font-size: var(--fs-sm);
  font-weight: 700;
  letter-spacing: 0.06em;
  display: block;
  margin-bottom: var(--sp-3);
}
.step-title {
  font-size: var(--fs-lg);
  font-weight: 600;
  letter-spacing: -0.015em;
  margin-bottom: var(--sp-2);
}
.step-desc { font-size: var(--fs-sm); color: var(--text-secondary); line-height: 1.65; }

/* ── Services ── */
.services-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.service-card {
  background: var(--surface);
  padding: var(--sp-4);
}
.service-dor {
  font-size: var(--fs-sm);
  color: var(--text-muted);
  font-style: italic;
  margin-bottom: var(--sp-2);
  line-height: 1.5;
}
.service-sol {
  font-size: var(--fs-lg);
  font-weight: 600;
  letter-spacing: -0.015em;
  color: var(--accent);
  margin-bottom: var(--sp-2);
}
.service-desc { font-size: var(--fs-sm); color: var(--text-secondary); line-height: 1.65; }

/* ── FAQ ── */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.faq-item {
  border-bottom: 1px solid var(--border);
}
.faq-item:first-of-type {
  border-top: 1px solid var(--border);
}
.faq-q {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-4);
  padding: var(--sp-4) 0;
  cursor: pointer;
  list-style: none;
  font-size: var(--fs-md);
  font-weight: 600;
  color: var(--text-primary);
  transition: color 0.15s;
}
.faq-q::-webkit-details-marker { display: none; }
.faq-q dt { font-size: inherit; font-weight: inherit; }
.faq-q:hover { color: var(--accent); }
.faq-icon {
  font-size: 20px;
  font-weight: 300;
  color: var(--text-muted);
  flex-shrink: 0;
  transition: transform 0.2s, color 0.15s;
  line-height: 1;
}
.faq-item[open] .faq-icon {
  transform: rotate(45deg);
  color: var(--accent);
}
.faq-a {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.75;
  padding-bottom: var(--sp-4);
}

/* ── Form ── */
.contact-sub { color: var(--text-secondary); margin-bottom: var(--sp-4); }
.contact-form { display: flex; flex-direction: column; gap: var(--sp-2); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-2); }
.form-input, .form-textarea {
  font-family: 'DM Sans', sans-serif;
  font-size: var(--fs-sm);
  padding: 12px var(--sp-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  background: var(--surface);
  color: var(--text-primary);
  transition: border-color 0.15s;
  resize: vertical;
}
.form-input:focus, .form-textarea:focus {
  outline: none;
  border-color: var(--accent);
}

/* ── Footer ── */
.footer { border-top: 1px solid var(--border); padding: var(--sp-3) 0; }
.footer-inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  min-height: 48px;
}
.footer-logo { display: flex; align-items: center; line-height: 0; justify-self: start; }
.footer-logo :global(svg) { width: 20px; height: auto; }
.footer-logo :global(svg path) { fill: var(--text-primary); stroke: none; }
.footer-copy { font-size: var(--fs-xs); color: var(--text-muted); text-align: center; }
.footer-back { justify-self: end; font-size: var(--fs-sm); color: var(--text-muted); transition: color 0.15s; }
.footer-back:hover { color: var(--text-primary); }

@media (max-width: 768px) {
  .capture-card { padding: var(--sp-4); }
  .steps-grid { grid-template-columns: 1fr; }
  .services-grid { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
}
</style>
