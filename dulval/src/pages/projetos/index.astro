<style>
.page-header {
  padding: var(--sp-6) 0 var(--sp-5);
  border-bottom: 1px solid var(--border);
}
.page-eyebrow {
  font-size: var(--fs-xs);
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: var(--sp-2);
}
.page-title {
  font-size: var(--fs-2xl);
  font-weight: 700;
  letter-spacing: -0.022em;
  line-height: 1.2;
}

.proj-stack {
  padding: var(--sp-5) 0 var(--sp-7);
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.project-card {
  display: grid;
  grid-template-columns: 1fr 220px;
  gap: var(--sp-5);
  align-items: center;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: var(--sp-4) var(--sp-5);
  position: sticky;
  top: 112px;
  transform-origin: top center;
  transition: background 0.15s;
  text-decoration: none;
  color: inherit;
}
.project-card:hover { background: var(--surface-dim); }

.proj-type {
  font-size: var(--fs-xs);
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
  display: block;
  margin-bottom: var(--sp-2);
}
.proj-name {
  font-size: 28px;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: var(--sp-2);
}
.proj-desc {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--sp-3);
}
.proj-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.proj-tag {
  font-size: var(--fs-xs);
  padding: 3px 9px;
  border: 1px solid var(--border);
  border-radius: 100px;
  color: var(--text-muted);
  background: var(--surface-dim);
}

.proj-visual {
  height: 140px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--surface-dim);
  flex-shrink: 0;
}
.proj-visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: grayscale(30%);
  opacity: 0.9;
  transition: opacity 0.2s;
}
.project-card:hover .proj-visual img { opacity: 1; filter: none; }

.proj-cta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: var(--fs-xs);
  font-weight: 500;
  color: var(--text-muted);
  margin-top: var(--sp-1);
  transition: color 0.15s;
}
.project-card:hover .proj-cta { color: var(--text-primary); }

@media (max-width: 640px) {
  .project-card { grid-template-columns: 1fr; }
  .proj-visual { height: 180px; }
}
</style>

<script>
(function () {
  const stack = document.getElementById('proj-stack');
  if (!stack) return;
  const cards = Array.from(stack.querySelectorAll('.project-card')) as HTMLElement[];
  const STICKY_TOP = 112;

  cards.forEach((card, i) => {
    card.style.zIndex = String(60 + i + 1);
  });

  function tick() {
    cards.forEach((card, i) => {
      if (i >= cards.length - 1) return;
      const rect = card.getBoundingClientRect();
      const nextRect = cards[i + 1].getBoundingClientRect();
      if (rect.top > STICKY_TOP + 2) {
        card.style.transform = '';
        return;
      }
      const progress = Math.max(0, Math.min(1,
        (window.innerHeight - nextRect.top) / (window.innerHeight - STICKY_TOP)
      ));
      const scale = 1 - progress * 0.05;
      const ty = -progress * 7;
      card.style.transform = `scale(${scale.toFixed(4)}) translateY(${ty.toFixed(2)}px)`;
    });
  }

  window.addEventListener('scroll', tick, { passive: true });
  tick();
}());
</script>
