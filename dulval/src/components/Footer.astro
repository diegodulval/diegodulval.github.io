---
import logoRaw from '../assets/dd-logo.svg?raw';
---
<footer class="footer">
  <div class="container footer-inner">

    <a href="/" class="footer-logo" aria-label="Início" set:html={logoRaw} />

    <p class="footer-copy">feito com amor &amp; claude.code &nbsp;·&nbsp; © dulval 2026</p>

    <a
      href="https://instagram.com/diegodulval"
      target="_blank"
      rel="noopener noreferrer"
      class="footer-ig"
      aria-label="Instagram"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <circle cx="12" cy="12" r="4.5"/>
        <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
      </svg>
    </a>

  </div>
</footer>

<style>
.footer {
  border-top: 1px solid var(--border);
  padding: var(--sp-3) 0;
}

.footer-inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  min-height: 48px;
}

/* Logo esquerda */
.footer-logo {
  display: flex;
  align-items: center;
  line-height: 0;
  justify-self: start;
}

.footer-logo :global(svg) {
  width: 22px;
  height: auto;
}

.footer-logo :global(svg path) {
  fill: var(--text-primary);
  stroke: none;
}

/* Copy centralizado */
.footer-copy {
  font-size: var(--fs-xs);
  color: var(--text-muted);
  letter-spacing: 0.01em;
  white-space: nowrap;
  text-align: center;
}

/* Instagram direita */
.footer-ig {
  display: flex;
  align-items: center;
  justify-self: end;
  color: var(--text-muted);
  opacity: 0.5;
  transition: opacity 0.2s;
}

.footer-ig:hover {
  opacity: 1;
}
</style>
