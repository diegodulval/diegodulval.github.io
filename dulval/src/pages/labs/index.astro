---
import Layout from '../../layouts/Layout.astro';
import logoRaw from '../../assets/dd-logo.svg?raw';

const projetos = [
  {
    nome: 'DiMata',
    desc: 'Classificação visual de grãos de café por IA. Visão computacional em tempo real para beneficiamento.',
    categoria: 'AgriTech · CV',
    status: 'beta',
    pct: 70,
  },
  {
    nome: 'PriMata',
    desc: 'Monitoramento inteligente de secagem de café. Sensores + IA + alertas via WhatsApp.',
    categoria: 'AgriTech · IoT',
    status: 'em desenvolvimento',
    pct: 40,
  },
  {
    nome: 'Conecta Agent',
    desc: 'Framework interno para construção de agentes de automação com LLMs. Base do conecta.dulval.',
    categoria: 'AI · Infra',
    status: 'ativo',
    pct: 85,
  },
  {
    nome: 'Café E-commerce',
    desc: 'Plataforma de venda direta e clube de assinatura para o café.dulval.',
    categoria: 'E-commerce',
    status: 'planejado',
    pct: 10,
  },
  {
    nome: 'Dulval OS',
    desc: 'Sistema operacional pessoal — segundo cérebro integrado com IA para gestão de conhecimento e projetos.',
    categoria: 'Produtividade · AI',
    status: 'experimento',
    pct: 20,
  },
];

const graveyard = [
  {
    nome: 'BluMonkey MVP',
    desc: 'Marketplace de serviços educacionais. Chegou à fase de produto mas não encontrou tração.',
    epitafio: '2019–2021',
  },
  {
    nome: 'FAI NPDI Toolkit',
    desc: 'Ferramentas de gestão para laboratórios de inovação universitários. Descontinuado por falta de budget institucional.',
    epitafio: '2018–2020',
  },
  {
    nome: 'Noh Analytics v1',
    desc: 'Primeiro sistema de analytics interno da Noh. Substituído por abordagem mais robusta com BigQuery.',
    epitafio: '2022',
  },
];

const statusMap: Record<string, { color: string; label: string }> = {
  beta:              { color: '#22c55e', label: 'Beta' },
  ativo:             { color: '#3b82f6', label: 'Ativo' },
  'em desenvolvimento': { color: '#a78bfa', label: 'Em dev' },
  planejado:         { color: '#f59e0b', label: 'Planejado' },
  experimento:       { color: '#fb923c', label: 'Experimento' },
};
---

<Layout
  title="labs.dulval — Laboratório de ideias e experimentos"
  description="Roadmap público de projetos, iniciativas em desenvolvimento, waitlist e o graveyard — onde as boas ideias descansam."
>

<style is:global>
  body { padding-top: 0; }
  :root { --accent: #a78bfa; }
</style>

<!-- NAV -->
<nav class="portal-nav">
  <div class="container portal-nav-inner">
    <a href="/" class="portal-logo" set:html={logoRaw} />
    <span class="portal-nav-name">labs.dulval</span>
    <a href="https://dulval.com" class="portal-nav-back">← ecossistema</a>
  </div>
</nav>

<!-- HERO -->
<section class="labs-hero">
  <div class="container">
    <span class="eyebrow" style="color: var(--accent);">Laboratório · Experimentos · Roadmap público</span>
    <h1 class="labs-hero-title">Onde as ideias<br>ganham forma.</h1>
    <p class="labs-hero-body">
      Um espaço para construir em público — projetos em andamento, experimentos que podem não virar nada
      e um graveyard honesto das ideias que não sobreviveram.
    </p>
    <a href="#waitlist" class="btn btn-primary" style="background: var(--accent);">Entrar na waitlist</a>
  </div>
</section>

<!-- ROADMAP -->
<section class="section" id="roadmap">
  <div class="container">
    <span class="eyebrow">Roadmap público</span>
    <h2 class="s-title">O que está em construção.</h2>
    <div class="roadmap-list">
      {projetos.map((p) => {
        const s = statusMap[p.status] ?? { color: '#888', label: p.status };
        return (
          <div class="roadmap-item">
            <div class="roadmap-header">
              <div class="roadmap-info">
                <h3 class="roadmap-nome">{p.nome}</h3>
                <span class="roadmap-cat">{p.categoria}</span>
              </div>
              <span
                class="roadmap-badge"
                style={`background: ${s.color}1a; color: ${s.color};`}
              >{s.label}</span>
            </div>
            <p class="roadmap-desc">{p.desc}</p>
            <div class="roadmap-progress-track">
              <div
                class="roadmap-progress-bar"
                style={`width: ${p.pct}%; background: ${s.color};`}
              ></div>
            </div>
            <span class="roadmap-pct" style={`color: ${s.color};`}>{p.pct}%</span>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- WAITLIST -->
<section class="section waitlist-section" id="waitlist">
  <div class="container waitlist-inner">
    <div class="waitlist-copy">
      <span class="eyebrow" style="color: var(--accent);">Waitlist</span>
      <h2 class="s-title">Quer ser o primeiro a testar?</h2>
      <p class="waitlist-body">
        Entre na lista e aviso quando qualquer projeto do labs chegar em beta.
        Sem spam — só o que realmente importa.
      </p>
    </div>
    <form class="waitlist-form" action="mailto:labs@dulval.com" method="get" enctype="text/plain">
      <input type="email" name="email" placeholder="Seu melhor e-mail" class="form-input" required />
      <select name="projeto" class="form-input">
        <option value="">Qual projeto te interessa mais?</option>
        {projetos.map((p) => <option value={p.nome}>{p.nome}</option>)}
        <option value="todos">Todos</option>
      </select>
      <button type="submit" class="btn btn-primary" style="background: var(--accent);">Entrar na waitlist →</button>
    </form>
  </div>
</section>

<!-- GRAVEYARD -->
<section class="section graveyard-section">
  <div class="container">
    <span class="eyebrow">Graveyard</span>
    <h2 class="s-title" style="color: var(--text-muted);">Projetos que descansam em paz.</h2>
    <p class="graveyard-intro">
      Todo laboratório tem um cemitério. Esses projetos não vingaram — mas cada um ensinou algo.
    </p>
    <div class="graveyard-grid">
      {graveyard.map((g) => (
        <div class="grave-card">
          <div class="grave-header">
            <span class="grave-epitafio">{g.epitafio}</span>
            <span class="grave-rip">R.I.P.</span>
          </div>
          <h3 class="grave-nome">{g.nome}</h3>
          <p class="grave-desc">{g.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <div class="container footer-inner">
    <a href="/" class="footer-logo" aria-label="Início" set:html={logoRaw} />
    <p class="footer-copy">labs.dulval.com &nbsp;·&nbsp; © dulval 2026</p>
    <a href="/me" class="footer-back">me.dulval →</a>
  </div>
</footer>

</Layout>

<style>
.portal-nav { height: 64px; border-bottom: 1px solid var(--border); display: flex; align-items: center; }
.portal-nav-inner { display: flex; align-items: center; gap: var(--sp-3); }
.portal-logo { display: flex; align-items: center; line-height: 0; }
.portal-logo :global(svg) { width: 22px; height: auto; }
.portal-logo :global(svg path) { fill: var(--text-primary); stroke: none; }
.portal-nav-name { font-size: var(--fs-sm); font-weight: 600; }
.portal-nav-back { margin-left: auto; font-size: var(--fs-sm); color: var(--text-muted); transition: color 0.15s; }
.portal-nav-back:hover { color: var(--text-primary); }

.labs-hero {
  padding: var(--sp-7) 0 var(--sp-6);
  border-bottom: 1px solid var(--border);
}
.labs-hero-title {
  font-size: var(--fs-hero);
  font-weight: 700;
  letter-spacing: -0.028em;
  line-height: 1.06;
  margin: var(--sp-3) 0 var(--sp-4);
  max-width: 560px;
}
.labs-hero-body {
  font-size: var(--fs-lg);
  color: var(--text-secondary);
  max-width: 500px;
  line-height: 1.65;
  margin-bottom: var(--sp-5);
}

.s-title {
  font-size: var(--fs-2xl);
  font-weight: 700;
  letter-spacing: -0.025em;
  margin: var(--sp-2) 0 var(--sp-4);
}

/* ── Roadmap ── */
.roadmap-list { display: flex; flex-direction: column; gap: 1px; background: var(--border); border-radius: var(--radius-md); overflow: hidden; }
.roadmap-item {
  background: var(--surface);
  padding: var(--sp-4);
  display: grid;
  grid-template-columns: 1fr auto;
  grid-template-rows: auto auto auto;
  column-gap: var(--sp-4);
  row-gap: var(--sp-2);
  align-items: start;
}
.roadmap-header { display: contents; }
.roadmap-info { grid-column: 1; }
.roadmap-badge {
  grid-column: 2;
  grid-row: 1;
  font-size: var(--fs-xs);
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 12px;
  border-radius: var(--radius-pill);
  white-space: nowrap;
  align-self: center;
}
.roadmap-nome { font-size: var(--fs-lg); font-weight: 600; letter-spacing: -0.015em; }
.roadmap-cat { font-size: var(--fs-xs); color: var(--text-muted); }
.roadmap-desc { grid-column: 1 / -1; font-size: var(--fs-sm); color: var(--text-secondary); line-height: 1.65; }
.roadmap-progress-track {
  grid-column: 1;
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
}
.roadmap-progress-bar { height: 100%; border-radius: 2px; transition: width 0.6s ease; }
.roadmap-pct { grid-column: 2; font-size: var(--fs-xs); font-weight: 600; align-self: center; }

/* ── Waitlist ── */
.waitlist-section { background: var(--surface-dim); }
.waitlist-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-6);
  align-items: center;
}
.waitlist-body { color: var(--text-secondary); line-height: 1.75; }
.waitlist-form { display: flex; flex-direction: column; gap: var(--sp-2); }
.form-input, select.form-input {
  font-family: 'DM Sans', sans-serif;
  font-size: var(--fs-sm);
  padding: 12px var(--sp-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  background: var(--surface);
  color: var(--text-primary);
  transition: border-color 0.15s;
  -webkit-appearance: none;
}
.form-input:focus, select.form-input:focus { outline: none; border-color: var(--accent); }

/* ── Graveyard ── */
.graveyard-section { opacity: 0.85; }
.graveyard-intro { color: var(--text-muted); margin-bottom: var(--sp-4); font-style: italic; }
.graveyard-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-2);
}
.grave-card {
  padding: var(--sp-4);
  border: 1px dashed var(--border);
  border-radius: var(--radius-md);
}
.grave-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--sp-2); }
.grave-epitafio { font-size: var(--fs-xs); color: var(--text-muted); }
.grave-rip { font-size: var(--fs-xs); color: var(--text-muted); font-weight: 600; letter-spacing: 0.1em; }
.grave-nome { font-size: var(--fs-lg); font-weight: 600; color: var(--text-secondary); margin-bottom: var(--sp-2); text-decoration: line-through; text-decoration-color: var(--border); }
.grave-desc { font-size: var(--fs-sm); color: var(--text-muted); line-height: 1.65; }

.footer { border-top: 1px solid var(--border); padding: var(--sp-3) 0; }
.footer-inner { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; min-height: 48px; }
.footer-logo { display: flex; align-items: center; line-height: 0; justify-self: start; }
.footer-logo :global(svg) { width: 20px; height: auto; }
.footer-logo :global(svg path) { fill: var(--text-primary); stroke: none; }
.footer-copy { font-size: var(--fs-xs); color: var(--text-muted); text-align: center; }
.footer-back { justify-self: end; font-size: var(--fs-sm); color: var(--text-muted); transition: color 0.15s; }
.footer-back:hover { color: var(--text-primary); }

@media (max-width: 768px) {
  .graveyard-grid { grid-template-columns: 1fr; }
  .waitlist-inner { grid-template-columns: 1fr; }
}
</style>
